{
  "collector": {
    "sources": ["hf-daily", "arxiv"],
    "keywords": [
      "GUI agent", "computer use", "web agent", "mobile agent",
      "VLM", "vision language model", "multimodal",
      "LLM agent", "agentic RL", "world model","hyperbolic","Embodied AI", "Visual Imitation Learning", "Reinforcement Learning"
    ],
    "days": 3,
    "min_score": 2,
    "top_n": 30
  },
  "digest": {
    "parallel_limit": 10,
    "timeout_minutes": 5,
    "retry_limit": 2
  },
  "survey": {
    "min_papers": 15,
    "output_dir": "Topics/",
    "sections": ["background", "methods", "benchmarks", "challenges", "future"]
  },
  "report": {
    "frequency": "daily",
    "output_dir": "Reports/"
  }
}